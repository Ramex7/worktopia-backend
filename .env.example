# Server
NODE_ENV=development
PORT=3000

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=worktopia
DB_USER=root
DB_PASS=your_secure_password

# JWT & Auth
ACCESS_TOKEN_SECRET=change_this_to_a_long_random_access_secret
REFRESH_TOKEN_SECRET=change_this_to_a_long_random_refresh_secret
ACCESS_TOKEN_LIFE=15m
REFRESH_TOKEN_LIFE=7d
SALT_ROUNDS=12

# Setup & Security
SETUP_TOKEN=your_secure_setup_token_for_install_endpoint
FRONTEND_URLS=http://localhost:5173,http://localhost:3000